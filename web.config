<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="500" subStatusCode="-1"/>
      <error statusCode="500" path="/error.cfm?v=2" responseMode="ExecuteURL"/>
      <remove statusCode="404" subStatusCode="-1"/>
      <error statusCode="404" path="/error.cfm" responseMode="ExecuteURL"/>
      <remove statusCode="403" subStatusCode="-1"/>
      <error statusCode="403" path="/error.cfm" responseMode="ExecuteURL"/>
    </httpErrors>
    <rewrite>
      <outboundRules>
        <rule name="HideCFErrors" preCondition="IsCFError" stopProcessing="true">
          <match filterByTags="None" pattern=".*"/>
          <action type="Rewrite" value="/error.cfm?v=2"/>
        </rule>
        <preConditions>
          <preCondition name="IsCFError" logicalGrouping="MatchAny">
            <add input="{RESPONSE_BODY}" pattern="Invalid CFML construct"/>
            <add input="{RESPONSE_BODY}" pattern="ColdFusion was looking at"/>
            <add input="{RESPONSE_BODY}" pattern="The CFML compiler was processing"/>
            <add input="{RESPONSE_BODY}" pattern="An exception occurred while"/>
            <add input="{RESPONSE_BODY}" pattern="coldfusion\.runtime\."/>
            <add input="{RESPONSE_BODY}" pattern="Error Occurred While Processing Request"/>
            <add input="{RESPONSE_BODY}" pattern="Variable .* is undefined"/>
            <add input="{RESPONSE_BODY}" pattern="Element .* is undefined"/>
            <add input="{RESPONSE_BODY}" pattern="The value .* cannot be converted"/>
            <add input="{RESPONSE_BODY}" pattern="java\.lang\."/>
            <add input="{RESPONSE_BODY}" pattern="java\.sql\."/>
            <add input="{RESPONSE_BODY}" pattern="com\.microsoft\.sqlserver"/>
            <add input="{RESPONSE_BODY}" pattern="lucee\.runtime\."/>
            <add input="{RESPONSE_BODY}" pattern="coldfusion\.filter\."/>
            <add input="{RESPONSE_BODY}" pattern="coldfusion\.tagext\."/>
            <add input="{RESPONSE_BODY}" pattern="Attribute validation error"/>
            <add input="{RESPONSE_BODY}" pattern="ColdFusion cannot determine"/>
            <add input="{RESPONSE_BODY}" pattern="You have attempted to dereference"/>
            <add input="{RESPONSE_BODY}" pattern="Expression: #[^#]"/>
            <add input="{RESPONSE_BODY}" pattern="Debugging information follows"/>
            <add input="{RESPONSE_BODY}" pattern="Stack Trace:"/>
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
  </system.webServer>
</configuration>
